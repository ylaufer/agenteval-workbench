{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Auto-Evaluation Output",
  "description": "Schema for auto-scoring engine output files.",
  "type": "object",
  "required": ["case_id", "scoring_type", "rubric_version", "dimensions", "auto_tags", "metadata"],
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "type": "string",
      "description": "Benchmark case identifier."
    },
    "scoring_type": {
      "type": "string",
      "const": "auto",
      "description": "Always 'auto' for auto-generated scores."
    },
    "rubric_version": {
      "type": "string",
      "description": "Version of the rubric used for scoring."
    },
    "dimensions": {
      "type": "object",
      "description": "Per-dimension scoring results, keyed by dimension name.",
      "additionalProperties": {
        "type": "object",
        "required": ["dimension_name", "score", "weight", "scale", "evidence_step_ids", "notes", "evaluator_type"],
        "additionalProperties": false,
        "properties": {
          "dimension_name": {
            "type": "string"
          },
          "score": {
            "type": ["integer", "null"],
            "description": "Score within rubric scale, or null if scoring failed."
          },
          "weight": {
            "type": "number"
          },
          "scale": {
            "type": "string",
            "description": "Rubric scale string, e.g. '0-2'."
          },
          "evidence_step_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "string"
          },
          "evaluator_type": {
            "type": "string",
            "enum": ["rule", "llm"]
          },
          "confidence": {
            "type": ["number", "null"],
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Optional confidence for LLM evaluators."
          },
          "error": {
            "type": ["string", "null"],
            "description": "Error message if scoring failed."
          }
        }
      }
    },
    "auto_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Failure tags detected by the tagger."
    },
    "metadata": {
      "type": "object",
      "required": ["timestamp"],
      "additionalProperties": true,
      "properties": {
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of when scoring was executed."
        },
        "model": {
          "type": ["string", "null"],
          "description": "LLM model identifier, if any LLM evaluator was used."
        },
        "evaluator_versions": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Version info per evaluator."
        }
      }
    }
  }
}
